@startuml
skinparam monochrome true

' ──────────────────────────────────────────
' Module : User Authentication
' Diagram: Use Case
' ──────────────────────────────────────────

actor Guest
actor "Registered User" as User
actor "System" as Sys

rectangle "Authentication Module" {
  usecase "UC-01 Register Account"     as UC01
  usecase "UC-02 Log In"               as UC02
  usecase "UC-03 Log Out"              as UC03
  usecase "UC-04 Reset Password"       as UC04
  usecase "UC-05 Validate Credentials" as UC05
  usecase "UC-06 Send Reset Email"     as UC06
}

Guest --> UC01
Guest --> UC02

User  --> UC02
User  --> UC03
User  --> UC04

UC02  ..> UC05 : <<include>>
UC04  ..> UC06 : <<include>>
UC06  --> Sys

@enduml
